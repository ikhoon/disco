#!/usr/bin/env bash
# Mock disco for the demo GIF (see ../demo.tape). Prints fictional output with
# the real color scheme baked in (green timestamp, cyan author, yellow ids,
# gray permalinks/labels, bold categories) so the recording shows disco's
# colored output. Never touches the Discord API. On PATH via demo/bin during
# `vhs demo/demo.tape` so it shadows the real binary.
set -euo pipefail

G=$'\033[92m'  # timestamp — green
C=$'\033[96m'  # author — cyan
Y=$'\033[93m'  # ids — yellow
D=$'\033[90m'  # permalinks / secondary — gray
B=$'\033[1m'   # category — bold
R=$'\033[0m'

GUILD=111111111111111111
CHAN=222222222222222222

hdr() { # time author [bot]
  printf '[%s%s%s] %s%s%s%s:\n' "$G" "$1" "$R" "$C" "$2" "$R" "${3:+$D $3$R}"
}
body() { printf '    %s\n' "$1"; }
link() { printf '    %s%s%s\n' "$D" "https://discord.com/channels/$GUILD/$CHAN/$1" "$R"; }

json="no"
for a in "$@"; do [[ "$a" == "--json" ]] && json="yes"; done

case "${1:-}" in
  mention)
    if [[ "$json" == "yes" ]]; then
      cat <<EOF
{
  "data": [
    {
      "id": "333333333333333333",
      "ts": "2026-07-04T08:41:12.000Z",
      "author": { "name": "Jane Doe", "bot": false },
      "content": "@ikhoon deploy failed on main — can you take a look?",
      "permalink": "https://discord.com/channels/$GUILD/$CHAN/333333333333333333"
    },
    {
      "id": "333333333333333444",
      "ts": "2026-07-04T08:55:03.000Z",
      "author": { "name": "CI Bot", "bot": true },
      "content": "build #1242 fixed by @ikhoon",
      "permalink": "https://discord.com/channels/$GUILD/$CHAN/333333333333333444"
    }
  ]
}
EOF
      exit 0
    fi
    echo "2 mention(s) since 2026-07-04T07:00:00.000Z" >&2
    hdr "2026-07-04 08:41" "Jane Doe"
    body "@ikhoon deploy failed on main — can you take a look?"
    link 333333333333333333
    echo
    hdr "2026-07-04 08:55" "CI Bot" "[bot]"
    body "build #1242 fixed by @ikhoon"
    link 333333333333333444
    ;;
  search)
    echo "2 of 2 result(s) in guild $GUILD" >&2
    hdr "2026-07-04 08:41" "Jane Doe"
    body "@ikhoon deploy failed on main — can you take a look?"
    link 333333333333333333
    echo
    hdr "2026-07-03 17:20" "Alex Kim"
    body "deploy failed twice on staging — rollback went out, postmortem doc in the thread"
    link 333333333333333222
    ;;
  channels)
    echo "5 channel(s) in guild $GUILD" >&2
    printf '  # welcome  %s%s%s\n' "$Y" 222222222222222200 "$R"
    printf '\n▸ %sENGINEERING%s\n' "$B" "$R"
    printf '  # deploys  %s%s%s\n' "$Y" "$CHAN" "$R"
    printf '  # backend  %s%s%s\n' "$Y" 222222222222222223 "$R"
    printf '  🧵 release-1-42  %s%s%s\n' "$Y" 222222222222222224 "$R"
    ;;
  *)
    echo "disco: (demo mock) unhandled command: ${*:-}" >&2
    exit 1
    ;;
esac
